# Public access
APP_PORT=8080
PUBLIC_FRONTEND_URL=https://iekaclass.vercel.app
PUBLIC_FILES_BASE_URL=https://your-domain.com/api/LearningStorage/download
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://api:8080
STORAGE_USE_BLOB_STORAGE=false
HOST_DB_PATH=/storage/ieka/db
HOST_STORAGE_PATH=/storage/ieka/files
HOST_BACKUP_PATH=/storage/ieka/backups

# Database
DB_NAME=IekaSmartClassDb
MSSQL_SA_PASSWORD=ChangeThisToAVeryStrongPassword!123

# JWT
JWT_SECRET=ReplaceWithAtLeast32CharactersLongRandomSecret
JWT_ISSUER=IekaSmartClass.Api
JWT_AUDIENCE=IekaSmartClass.Web

# SMTP (set real values in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=no-reply@your-domain.com
SMTP_FROM_NAME=IEKA SmartClass

# Security / auth
TWO_FACTOR_ENABLED=true

# Backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
