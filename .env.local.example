# Local development environment — copy to .env.local before running docker-compose.local.yml
# cp .env.local.example .env.local

APP_PORT=8080

# Database
DB_NAME=IekaSmartClassDb
MSSQL_SA_PASSWORD=LocalDev#Password123

# JWT
JWT_SECRET=LocalDevJwtSecret32CharsAtLeastLong!
JWT_ISSUER=IekaSmartClass.Api
JWT_AUDIENCE=IekaSmartClass.Web

# SMTP — leave blank to skip sending emails locally
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@localhost
SMTP_FROM_NAME=IEKA SmartClass (Local)

# Disable 2FA for easier local testing
TWO_FACTOR_ENABLED=false
